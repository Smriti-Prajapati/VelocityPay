# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=velocitypay
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info
CORS_ALLOW_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=velocitypay
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MAX_IDLE=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a strong random secret in production
JWT_SECRET=super-secret-jwt-key-change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
